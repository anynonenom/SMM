{
  "name": "eiden-smm-analytics",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["frontend", "worker", "backend"],
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:worker": "cd worker && npm run dev",
    "dev:backend": "cd  backend  && npm run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:worker\" \"npm run dev:backend\"",
    "deploy:worker": "cd worker && npm run deploy",
    "deploy:frontend": "cd frontend && npm run build",
    "deploy:backend": "cd backend && npm run deploy"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
