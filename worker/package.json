    "db:create": "wrangler d1 create eiden-smm-db",
    "r2:create": "wrangler r2 bucket create eiden-smm-csvs"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240725.0",
    "typescript": "^5.5.4",
    "wrangler": "^4.81.1"
  }
}
